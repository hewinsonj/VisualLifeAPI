# visual-life-api — copy to .env and fill in (never commit real values)

PORT=8000
NODE_ENV=development

# Database
MONGODB_URI=

# Frontend origin(s) allowed by CORS. Comma-separate for multiple; the FIRST is the
# canonical origin used to build emailed links (e.g. password reset).
# Prod (Fly secret): https://visuallife.app,https://visuallife.netlify.app
CLIENT_ORIGIN=http://localhost:5173

# Access control
SIGNUP_MODE=invite            # "invite" (default) requires a code; "open" allows self-signup

# Trial / limits
TRIAL_DAYS=14
TRIAL_PRESET_LIMIT=5

# Stripe (test keys locally, live keys in prod)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Error tracking (optional — leave blank to disable Sentry)
SENTRY_DSN=

# Transactional email via Resend (optional — leave RESEND_API_KEY blank to disable email)
RESEND_API_KEY=
EMAIL_FROM="Visual Life <onboarding@resend.dev>"   # must be a Resend-verified domain to email real users
EMAIL_REPLY_TO=visuallife@proton.me                 # where user replies land
