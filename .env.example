# visual-life-api — copy to .env and fill in (never commit real values)

PORT=8000
NODE_ENV=development

# Database
MONGODB_URI=

# Frontend origin allowed by CORS (prod Netlify URL in production)
CLIENT_ORIGIN=http://localhost:5173

# Access control
SIGNUP_MODE=invite            # "invite" (default) requires a code; "open" allows self-signup

# Trial / limits
TRIAL_DAYS=14
TRIAL_PRESET_LIMIT=5

# Stripe (test keys locally, live keys in prod)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Error tracking (optional — leave blank to disable Sentry)
SENTRY_DSN=
